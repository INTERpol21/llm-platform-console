{
  "openapi": "3.1.0",
  "info": {
    "title": "rag-pgvector",
    "description": "RAG service: ingest -> chunk -> embed -> vector search -> LLM synthesis with [n] citations.",
    "version": "0.1.0"
  },
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Healthz",
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/ingest": {
      "post": {
        "summary": "Ingest",
        "operationId": "ingest_v1_ingest_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IngestRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/ingest/file": {
      "post": {
        "summary": "Ingest File",
        "description": "Upload a md/txt/pdf/docx file; its text is extracted and ingested.",
        "operationId": "ingest_file_v1_ingest_file_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_ingest_file_v1_ingest_file_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/query": {
      "post": {
        "summary": "Query",
        "operationId": "query_v1_query_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/stats": {
      "get": {
        "summary": "Stats",
        "operationId": "stats_v1_stats_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatsResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Body_ingest_file_v1_ingest_file_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title"
          },
          "source": {
            "type": "string",
            "enum": [
              "local",
              "web",
              "other"
            ],
            "title": "Source",
            "default": "local"
          },
          "owner": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Owner"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_ingest_file_v1_ingest_file_post"
      },
      "CitationOut": {
        "properties": {
          "document_id": {
            "type": "string",
            "title": "Document Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "chunk_id": {
            "type": "string",
            "title": "Chunk Id"
          },
          "snippet": {
            "type": "string",
            "title": "Snippet"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "source": {
            "type": "string",
            "title": "Source",
            "default": "local"
          }
        },
        "type": "object",
        "required": [
          "document_id",
          "title",
          "chunk_id",
          "snippet",
          "score"
        ],
        "title": "CitationOut"
      },
      "DocumentIn": {
        "properties": {
          "id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Id"
          },
          "title": {
            "type": "string",
            "maxLength": 1000,
            "minLength": 1,
            "title": "Title"
          },
          "text": {
            "type": "string",
            "maxLength": 1000000,
            "minLength": 1,
            "title": "Text"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata"
          },
          "source": {
            "type": "string",
            "enum": [
              "local",
              "web",
              "other"
            ],
            "title": "Source",
            "default": "local"
          },
          "priority": {
            "type": "integer",
            "maximum": 1000.0,
            "minimum": 0.0,
            "title": "Priority",
            "default": 100
          },
          "owner": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 1000
              },
              {
                "type": "null"
              }
            ],
            "title": "Owner"
          }
        },
        "type": "object",
        "required": [
          "title",
          "text"
        ],
        "title": "DocumentIn"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "default": "ok"
          }
        },
        "type": "object",
        "title": "HealthResponse",
        "description": "Liveness probe payload."
      },
      "IngestRequest": {
        "properties": {
          "documents": {
            "items": {
              "$ref": "#/components/schemas/DocumentIn"
            },
            "type": "array",
            "maxItems": 100,
            "minItems": 1,
            "title": "Documents"
          }
        },
        "type": "object",
        "required": [
          "documents"
        ],
        "title": "IngestRequest"
      },
      "IngestResponse": {
        "properties": {
          "document_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Document Ids"
          },
          "chunks_indexed": {
            "type": "integer",
            "title": "Chunks Indexed"
          },
          "skipped": {
            "type": "integer",
            "title": "Skipped"
          }
        },
        "type": "object",
        "required": [
          "document_ids",
          "chunks_indexed",
          "skipped"
        ],
        "title": "IngestResponse"
      },
      "QueryRequest": {
        "properties": {
          "question": {
            "type": "string",
            "maxLength": 10000,
            "minLength": 1,
            "title": "Question"
          },
          "top_k": {
            "type": "integer",
            "maximum": 20.0,
            "minimum": 1.0,
            "title": "Top K",
            "default": 4
          },
          "sources": {
            "anyOf": [
              {
                "items": {
                  "type": "string",
                  "enum": [
                    "local",
                    "web",
                    "other"
                  ]
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sources"
          }
        },
        "type": "object",
        "required": [
          "question"
        ],
        "title": "QueryRequest"
      },
      "QueryResponse": {
        "properties": {
          "answer": {
            "type": "string",
            "title": "Answer"
          },
          "citations": {
            "items": {
              "$ref": "#/components/schemas/CitationOut"
            },
            "type": "array",
            "title": "Citations"
          },
          "retrieved": {
            "items": {
              "$ref": "#/components/schemas/RetrievedChunkOut"
            },
            "type": "array",
            "title": "Retrieved"
          },
          "usage": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Usage"
          }
        },
        "type": "object",
        "required": [
          "answer",
          "citations",
          "retrieved"
        ],
        "title": "QueryResponse"
      },
      "RetrievedChunkOut": {
        "properties": {
          "chunk_id": {
            "type": "string",
            "title": "Chunk Id"
          },
          "document_id": {
            "type": "string",
            "title": "Document Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "ord": {
            "type": "integer",
            "title": "Ord"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "source": {
            "type": "string",
            "title": "Source",
            "default": "local"
          }
        },
        "type": "object",
        "required": [
          "chunk_id",
          "document_id",
          "title",
          "ord",
          "score"
        ],
        "title": "RetrievedChunkOut"
      },
      "StatsResponse": {
        "properties": {
          "backend": {
            "type": "string",
            "title": "Backend"
          },
          "documents": {
            "type": "integer",
            "title": "Documents"
          },
          "chunks": {
            "type": "integer",
            "title": "Chunks"
          },
          "embeddings_backend": {
            "type": "string",
            "title": "Embeddings Backend"
          },
          "llm_backend": {
            "type": "string",
            "title": "Llm Backend"
          },
          "embedding_dim": {
            "type": "integer",
            "title": "Embedding Dim"
          },
          "search_mode": {
            "type": "string",
            "title": "Search Mode"
          },
          "reranker": {
            "type": "string",
            "title": "Reranker"
          }
        },
        "type": "object",
        "required": [
          "backend",
          "documents",
          "chunks",
          "embeddings_backend",
          "llm_backend",
          "embedding_dim",
          "search_mode",
          "reranker"
        ],
        "title": "StatsResponse",
        "description": "Store counts plus the active backends (see the ``/stats`` route)."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}