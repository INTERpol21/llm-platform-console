{
  "openapi": "3.1.0",
  "info": {
    "title": "agent-orchestrator",
    "description": "LangGraph multi-step research agent orchestrating llm-gateway, rag-pgvector and mcp-tools-server.",
    "version": "1.0.0"
  },
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Healthz",
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Healthz Healthz Get"
                }
              }
            }
          }
        }
      }
    },
    "/research": {
      "post": {
        "summary": "Research",
        "operationId": "research_research_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResearchRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResearchResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/research/stream": {
      "post": {
        "summary": "Research Stream",
        "description": "Stream the agent's trace live over SSE, then a final ``result`` event.\n\nUses ``astream(stream_mode=[\"updates\", \"custom\"])`` (not ``astream_events``,\nwhich does not compose with a checkpointer): each node's ``trace`` delta is\nrelayed as it happens; answer/evidence/iterations are accumulated for the\nterminal ``result`` event, closed by ``[DONE]``.",
        "operationId": "research_stream_research_stream_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResearchRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/research/history/{thread_id}": {
      "get": {
        "summary": "Research History",
        "description": "Return the latest persisted snapshot for a session, or ``exists=false``.\n\nReads straight from the checkpointer, so it works across restarts when a\ndurable backend is configured and reflects only committed supersteps.",
        "operationId": "research_history_research_history__thread_id__get",
        "parameters": [
          {
            "name": "thread_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Thread Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResearchHistoryResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/research/runs": {
      "get": {
        "summary": "Research Runs",
        "description": "List recent research-run telemetry, newest first, with cursor pagination.\n\n``enabled=false`` (and an empty page) when no telemetry database is\nconfigured. Pass the returned ``next_cursor`` back as ``cursor`` for the\nnext page; it is null on the last page.",
        "operationId": "research_runs_research_runs_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "title": "Limit"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Cursor"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResearchRunsPage"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Evidence": {
        "properties": {
          "source": {
            "type": "string",
            "enum": [
              "rag",
              "web"
            ],
            "title": "Source"
          },
          "ref": {
            "type": "string",
            "title": "Ref",
            "description": "Document title or URL the content came from"
          },
          "content": {
            "type": "string",
            "title": "Content"
          },
          "score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Score"
          }
        },
        "type": "object",
        "required": [
          "source",
          "ref",
          "content"
        ],
        "title": "Evidence",
        "description": "One piece of retrieved evidence, cited as ``[n]`` in the final answer."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ResearchHistoryResponse": {
        "properties": {
          "thread_id": {
            "type": "string",
            "title": "Thread Id"
          },
          "exists": {
            "type": "boolean",
            "title": "Exists"
          },
          "question": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Question"
          },
          "answer": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Answer"
          },
          "evidence": {
            "items": {
              "$ref": "#/components/schemas/Evidence"
            },
            "type": "array",
            "title": "Evidence"
          },
          "trace": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Trace"
          },
          "iterations": {
            "type": "integer",
            "title": "Iterations",
            "default": 0
          },
          "checkpoints": {
            "type": "integer",
            "title": "Checkpoints",
            "description": "Number of persisted checkpoints (superstep snapshots)",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "thread_id",
          "exists"
        ],
        "title": "ResearchHistoryResponse",
        "description": "Latest checkpointed snapshot for a ``thread_id`` (empty if unknown)."
      },
      "ResearchRequest": {
        "properties": {
          "question": {
            "type": "string",
            "maxLength": 4096,
            "minLength": 1,
            "title": "Question",
            "description": "Research question to answer"
          },
          "max_iterations": {
            "type": "integer",
            "maximum": 10.0,
            "minimum": 1.0,
            "title": "Max Iterations",
            "description": "Hard cap on reflection iterations",
            "default": 3
          },
          "thread_id": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 200
              },
              {
                "type": "null"
              }
            ],
            "title": "Thread Id",
            "description": "Session id for durable state. Reuse a prior thread_id to continue that session (resume/audit); omit to start a fresh one."
          },
          "mode": {
            "type": "string",
            "enum": [
              "priority",
              "strict"
            ],
            "title": "Mode",
            "description": "Local-first policy. 'priority' (default): consult your local data first, web supplements. 'strict': local only \u2014 no web fallback; if local coverage is missing the answer says so.",
            "default": "priority"
          },
          "model": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 200
              },
              {
                "type": "null"
              }
            ],
            "title": "Model",
            "description": "Gateway model id to use for this run (planner/reflector/synthesizer). Omit to use the orchestrator's configured default."
          }
        },
        "type": "object",
        "required": [
          "question"
        ],
        "title": "ResearchRequest",
        "description": "Body of ``POST /research``."
      },
      "ResearchResponse": {
        "properties": {
          "answer": {
            "type": "string",
            "title": "Answer"
          },
          "evidence": {
            "items": {
              "$ref": "#/components/schemas/Evidence"
            },
            "type": "array",
            "title": "Evidence"
          },
          "trace": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Trace"
          },
          "iterations": {
            "type": "integer",
            "title": "Iterations"
          },
          "thread_id": {
            "type": "string",
            "title": "Thread Id",
            "description": "Session id this run was recorded under"
          }
        },
        "type": "object",
        "required": [
          "answer",
          "evidence",
          "trace",
          "iterations",
          "thread_id"
        ],
        "title": "ResearchResponse",
        "description": "Result of a research run: the answer plus its full provenance."
      },
      "ResearchRunsPage": {
        "properties": {
          "items": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Items"
          },
          "next_cursor": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Next Cursor",
            "description": "Pass back as ?cursor= for the next page; null at the end"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled",
            "description": "False when no telemetry database is configured"
          }
        },
        "type": "object",
        "required": [
          "items",
          "enabled"
        ],
        "title": "ResearchRunsPage",
        "description": "A page of research-run telemetry, newest first, with a keyset cursor."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}