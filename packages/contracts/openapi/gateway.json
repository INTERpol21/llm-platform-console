{
  "openapi": "3.1.0",
  "info": {
    "title": "llm-gateway",
    "description": "OpenAI-compatible gateway for OpenAI / Anthropic / Ollama with caching, retries, fallbacks and cost tracking.",
    "version": "1.0.0"
  },
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Healthz",
        "description": "Liveness probe (unauthenticated).",
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Healthz Healthz Get"
                }
              }
            }
          }
        }
      }
    },
    "/v1/models": {
      "get": {
        "summary": "List Models",
        "description": "Explicit aliases plus one wildcard entry per passthrough provider.",
        "operationId": "list_models_v1_models_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelList"
                }
              }
            }
          }
        }
      }
    },
    "/v1/models/catalog": {
      "get": {
        "summary": "Models Catalog",
        "description": "Rich per-alias metadata: provider, status, pricing, context window, fallbacks.",
        "operationId": "models_catalog_v1_models_catalog_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/CatalogEntry"
                  },
                  "type": "array",
                  "title": "Response Models Catalog V1 Models Catalog Get"
                }
              }
            }
          }
        }
      }
    },
    "/v1/models/{model_id}/ping": {
      "get": {
        "summary": "Model Ping",
        "description": "Lightweight reachability + latency probe for one aliased model (no tokens).",
        "operationId": "model_ping_v1_models__model_id__ping_get",
        "parameters": [
          {
            "name": "model_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Model Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PingResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/usage": {
      "get": {
        "summary": "Usage Report",
        "description": "Aggregated usage and USD cost for the calling API key, per model.",
        "operationId": "usage_report_v1_usage_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsageReport"
                }
              }
            }
          }
        }
      }
    },
    "/v1/model-runs": {
      "get": {
        "summary": "Model Runs",
        "description": "Per-call model telemetry, newest first, with keyset cursor pagination.\n\n``enabled=false`` (empty page) when no telemetry database is configured. Pass\nthe returned ``next_cursor`` back as ``cursor`` for the next page.",
        "operationId": "model_runs_v1_model_runs_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "title": "Limit"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Cursor"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelRunsPage"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/chat/completions": {
      "post": {
        "summary": "Chat Completions",
        "operationId": "chat_completions_v1_chat_completions_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatCompletionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CatalogEntry": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "provider": {
            "type": "string",
            "title": "Provider"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "latency_ms": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Latency Ms"
          },
          "pricing": {
            "$ref": "#/components/schemas/ModelPricing"
          },
          "context_window": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Context Window"
          },
          "fallbacks": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Fallbacks"
          },
          "streaming": {
            "type": "boolean",
            "title": "Streaming",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "id",
          "provider",
          "status",
          "pricing"
        ],
        "title": "CatalogEntry",
        "description": "Rich metadata for one aliased model (beyond the OpenAI /v1/models shape)."
      },
      "ChatCompletionRequest": {
        "properties": {
          "model": {
            "type": "string",
            "title": "Model"
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            },
            "type": "array",
            "minItems": 1,
            "title": "Messages"
          },
          "temperature": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 2.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Temperature"
          },
          "max_tokens": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 1.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Tokens"
          },
          "stream": {
            "type": "boolean",
            "title": "Stream",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "model",
          "messages"
        ],
        "title": "ChatCompletionRequest",
        "description": "Subset of the OpenAI chat completion request we support."
      },
      "ChatMessage": {
        "properties": {
          "role": {
            "type": "string",
            "pattern": "^(system|user|assistant|tool)$",
            "title": "Role"
          },
          "content": {
            "type": "string",
            "title": "Content"
          }
        },
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "title": "ChatMessage",
        "description": "A single chat message in OpenAI format."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ModelInfo": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "object": {
            "type": "string",
            "title": "Object",
            "default": "model"
          },
          "created": {
            "type": "integer",
            "title": "Created"
          },
          "owned_by": {
            "type": "string",
            "title": "Owned By",
            "default": "llm-gateway"
          }
        },
        "type": "object",
        "required": [
          "id"
        ],
        "title": "ModelInfo",
        "description": "Entry of the /v1/models listing."
      },
      "ModelList": {
        "properties": {
          "object": {
            "type": "string",
            "title": "Object",
            "default": "list"
          },
          "data": {
            "items": {
              "$ref": "#/components/schemas/ModelInfo"
            },
            "type": "array",
            "title": "Data"
          }
        },
        "type": "object",
        "required": [
          "data"
        ],
        "title": "ModelList",
        "description": "Response of /v1/models."
      },
      "ModelPricing": {
        "properties": {
          "input_per_1k": {
            "type": "number",
            "title": "Input Per 1K"
          },
          "output_per_1k": {
            "type": "number",
            "title": "Output Per 1K"
          }
        },
        "type": "object",
        "required": [
          "input_per_1k",
          "output_per_1k"
        ],
        "title": "ModelPricing",
        "description": "USD cost per 1k tokens for a model."
      },
      "ModelRunOut": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "request_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Request Id"
          },
          "provider": {
            "type": "string",
            "title": "Provider"
          },
          "model": {
            "type": "string",
            "title": "Model"
          },
          "served_model": {
            "type": "string",
            "title": "Served Model"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "streaming": {
            "type": "boolean",
            "title": "Streaming"
          },
          "cache_hit": {
            "type": "boolean",
            "title": "Cache Hit"
          },
          "prompt_tokens": {
            "type": "integer",
            "title": "Prompt Tokens"
          },
          "completion_tokens": {
            "type": "integer",
            "title": "Completion Tokens"
          },
          "total_tokens": {
            "type": "integer",
            "title": "Total Tokens"
          },
          "context_window": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Context Window"
          },
          "context_used_pct": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Context Used Pct"
          },
          "cost_usd": {
            "type": "number",
            "title": "Cost Usd"
          },
          "total_ms": {
            "type": "number",
            "title": "Total Ms"
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "provider",
          "model",
          "served_model",
          "status",
          "streaming",
          "cache_hit",
          "prompt_tokens",
          "completion_tokens",
          "total_tokens",
          "cost_usd",
          "total_ms",
          "created_at"
        ],
        "title": "ModelRunOut",
        "description": "One per-call telemetry row as served by /v1/model-runs (read side)."
      },
      "ModelRunsPage": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/ModelRunOut"
            },
            "type": "array",
            "title": "Items"
          },
          "next_cursor": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Next Cursor"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled"
          }
        },
        "type": "object",
        "required": [
          "enabled"
        ],
        "title": "ModelRunsPage",
        "description": "A newest-first page of model-run telemetry with a keyset cursor.\n\n``enabled`` is false (and ``items`` empty) when no telemetry database is\nconfigured; pass ``next_cursor`` back as ``cursor`` for the next page."
      },
      "PingResult": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "provider": {
            "type": "string",
            "title": "Provider"
          },
          "configured": {
            "type": "boolean",
            "title": "Configured"
          },
          "reachable": {
            "type": "boolean",
            "title": "Reachable"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "latency_ms": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Latency Ms"
          },
          "checked_at": {
            "type": "integer",
            "title": "Checked At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "provider",
          "configured",
          "reachable",
          "status"
        ],
        "title": "PingResult",
        "description": "Result of a lightweight reachability probe for one model."
      },
      "UsageModelRow": {
        "properties": {
          "requests": {
            "type": "integer",
            "title": "Requests",
            "default": 0
          },
          "prompt_tokens": {
            "type": "integer",
            "title": "Prompt Tokens",
            "default": 0
          },
          "completion_tokens": {
            "type": "integer",
            "title": "Completion Tokens",
            "default": 0
          },
          "cost_usd": {
            "type": "number",
            "title": "Cost Usd",
            "default": 0.0
          }
        },
        "type": "object",
        "title": "UsageModelRow",
        "description": "Per-model usage aggregate (requests, tokens, USD cost) inside a report."
      },
      "UsageReport": {
        "properties": {
          "object": {
            "type": "string",
            "title": "Object",
            "default": "usage"
          },
          "api_key": {
            "type": "string",
            "title": "Api Key"
          },
          "requests": {
            "type": "integer",
            "title": "Requests",
            "default": 0
          },
          "prompt_tokens": {
            "type": "integer",
            "title": "Prompt Tokens",
            "default": 0
          },
          "completion_tokens": {
            "type": "integer",
            "title": "Completion Tokens",
            "default": 0
          },
          "cost_usd": {
            "type": "number",
            "title": "Cost Usd",
            "default": 0.0
          },
          "models": {
            "additionalProperties": {
              "$ref": "#/components/schemas/UsageModelRow"
            },
            "type": "object",
            "title": "Models"
          }
        },
        "type": "object",
        "required": [
          "api_key"
        ],
        "title": "UsageReport",
        "description": "Aggregated usage and USD cost for one API key, per model (/v1/usage)."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}