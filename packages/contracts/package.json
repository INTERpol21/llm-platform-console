{
  "name": "@console/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenAPI snapshots of the platform backends + generated TS types and Zod schemas (single source of truth, no schema drift).",
  "exports": {
    ".": "./src/index.ts",
    "./gateway": "./src/gateway/index.ts",
    "./rag": "./src/rag/index.ts",
    "./orchestrator": "./src/orchestrator/index.ts"
  },
  "scripts": {
    "generate": "kubb generate --config kubb.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@kubb/cli": "^4.39.2",
    "@kubb/core": "^4.39.2",
    "@kubb/plugin-oas": "^4.39.2",
    "@kubb/plugin-ts": "^4.39.2",
    "@kubb/plugin-zod": "^4.39.2",
    "typescript": "^5.9.2"
  }
}
