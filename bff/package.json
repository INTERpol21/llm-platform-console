{
  "name": "@console/bff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hono BFF: single entry that injects platform bearer keys and proxies (incl. transparent SSE) to gateway/rag/orchestrator.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --import tsx src/server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@console/contracts": "workspace:*",
    "@hono/node-server": "^2.0.10",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  }
}
