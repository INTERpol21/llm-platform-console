# Copy to .env for the umbrella `docker compose`. Defaults run the platform
# fully offline with mock models — no external calls, no keys required.

# --- Platform bearer keys (matched across services; the BFF injects them) ---
PLATFORM_KEY=demo-key

# --- Postgres (shared: rag + orchestrator schemas live in one instance) ---
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform
# Embedding dimension for rag's pgvector column; must match the embedder.
EMBEDDING_DIM=256

# --- Optional real providers (leave blank to keep models as `not_configured`) ---
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
DASHSCOPE_API_KEY=

# --- Ollama (only with `--profile full`; real offline models) ---
# OLLAMA_URL=http://ollama:11434
