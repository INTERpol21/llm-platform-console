{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    // TS 7 removed baseUrl; paths are resolved relative to this file instead.
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
