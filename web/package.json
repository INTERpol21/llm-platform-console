    "@tanstack/react-router": "^1.87.0",
    "i18next": "^26.3.6",
    "lucide-react": "^1.25.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.10",
    "recharts": "^3.9.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.2"
