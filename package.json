{
  "name": "llm-platform-console",
  "version": "1.2.0",
  "private": true,
  "description": "Web console over the LLM platform (gateway, rag-pgvector, mcp-tools-server, agent-orchestrator).",
  "type": "module",
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
  "engines": {
    "node": ">=26",
    "pnpm": ">=11"
  },
  "scripts": {
    "contracts": "pnpm --filter @console/contracts generate",
    "dev:web": "pnpm --filter @console/web dev",
    "dev:bff": "pnpm --filter @console/bff dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "typescript": "^7.0.2"
  }
}
